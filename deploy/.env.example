# ReadingSteiner WebUI 运行环境变量
# 复制为 .env 并填入真实值。⚠️ .env 绝不进 git（见 .gitignore）。

# ── 网络边界（P0）────────────────────────────────────────────
# 必须是 127.0.0.1，绝不 0.0.0.0。EverOS 应用层裸奔，写记忆入口禁公网。
WEBUI_HOST=127.0.0.1
WEBUI_PORT=8761

# ── 鉴权（P0）──────────────────────────────────────────────
# 强随机长字符串。留空 → 写接口 503 拒绝裸奔。
# 生成：python -c "import secrets;print(secrets.token_urlsafe(32))"
WEBUI_AUTH_SECRET=
WEBUI_SESSION_TTL=28800

# ── EverOS 对接 ────────────────────────────────────────────
# 生产环境：EverOS 是宿主 venv + systemd
# everos.service（非 Docker），监听 127.0.0.1:8596。WebUI 与 EverOS 同机时直连 8596。
EVEROS_BASE_URL=http://127.0.0.1:8596
EVEROS_TIMEOUT=90

# ── 插件配置（第一期 covenant_store 用）─────────────────────
# 服务器上插件配置文件路径（含 eternal_covenant 字段，带 UTF-8 BOM）。
PLUGIN_CONFIG_PATH=/home/youruser/qqbot/astrbot/data/config/astrbot_plugin_readingsteiner_config.json

# ── EverOS markdown 根（第二三期改 md + cascade 用）────────
# = everos.core.persistence.MemoryRoot.root。第一期不碰 md，留空。
# 例：/home/youruser/.everos
# 注：app_id=astrbot、project_id=default 在磁盘映射为 default_project 目录
# （~/.everos/astrbot/default_project/users/<QQ>/），everos_gateway 会用 MemoryRoot 解析，勿手拼。
EVEROS_MEMORY_ROOT=

# ── everos CLI 可执行文件（cascade_sync / episode 删除重索引用，二期）─────
# 真机验证坐实：`everos` 装在 EverOS 自己的 venv 里，不在登录 shell
# 或 systemd 服务默认 PATH 上，裸命令会 subprocess FileNotFoundError。留空 = 用
# 默认裸名"everos"（仅当你的环境已把该 venv 加进 PATH 才够）；生产按实测路径填
# 全路径，例：/home/youruser/everos/.venv/bin/everos。main.py 的 lifespan 把这
# 同一个值分别传给 everos_gateway.HTTPEverOSGateway 和 episode_editor.EpisodeEditor
# ——两套独立的子进程调用（各自面向不同调用方），配置共享但代码不共享。
EVEROS_BIN=/home/youruser/everos/.venv/bin/everos

# ── 审计日志 / 数据目录 ─────────────────────────────────────
WEBUI_AUDIT_LOG=data/audit.jsonl
WEBUI_DATA_DIR=data

# ── 前端静态托管（生产）─────────────────────────────────────
# npm run build 产物目录（绝对路径）。FastAPI 同进程、同源托管前端，免 CORS、单端口、最省内存。
# 留空 = 不挂载（仅开发期 vite dev server 用）。
WEBUI_FRONTEND_DIR=/home/youruser/readingsteiner-webui/frontend/build

# ── covenant 只读开关 ───────────────────────────────────────
# 联调期=1 防误改生产铭契（写接口一律 502）；真机验收通过、正式放开写时再置 0。
WEBUI_COVENANT_READONLY=1